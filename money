<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stars Premium</title>
  <style>
    body { font-family: Arial, sans-serif; background: #1e1e2f; color: #fff; text-align: center; padding: 20px; }
    h1 { color: gold; }
    button { background: #0057ff; color: white; border: none; padding: 15px 30px; font-size: 18px; margin: 10px; border-radius: 8px; cursor: pointer; }
    button:hover { background: #0041bb; }
    .stars { font-size: 22px; margin: 20px 0; }
  </style>
</head>
<body>
  <h1>⭐ Stars Premium</h1>
  <p class="stars">O‘zingizga kerakli miqdorni tanlang:</p>

  <button onclick="buyStars(50)">50 Stars - 11 000 UZS</button>
  <button onclick="buyStars(100)">100 Stars - 22 000 UZS</button>
  <button onclick="buyStars(250)">250 Stars - 55 000 UZS</button>
  <button onclick="buyStars(500)">500 Stars - 110 000 UZS</button>

  <script>
    function buyStars(amount) {
      // Mini App orqali botga ma'lumot yuboradi
      if (window.Telegram.WebApp) {
        window.Telegram.WebApp.sendData(`buy:${amount}`);
        alert(amount + " Stars tanlandi!");
      } else {
        alert("Telegram ichida oching!");
      }
    }
  </script>
</body>
</html>
